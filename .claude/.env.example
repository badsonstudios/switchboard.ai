# ─────────────────────────────────────────────────────────────────────────────
# .env.example — committed template. Copy to `.claude/.env` and fill in values:
#
#   Copy-Item .claude/.env.example .claude/.env      (PowerShell)
#   cp .claude/.env.example .claude/.env             (bash)
#
# The real `.claude/.env` is git-ignored and must NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# GitHub personal access token (usually unneeded — gh CLI is keyring-authed)
GITHUB_TOKEN=

# GitHub repository URL (not secret; convenience reference for tooling/scripts)
GITHUB_PROJECT=https://github.com/badsonstudios/switchboard.ai

# NOTE: There is intentionally NO ANTHROPIC_API_KEY. The `claude` CLI runs on
# Dan's subscription — both for dev tooling and as the product's target.
# The app stores end-user credentials in the OS credential store, never files.

# Optional overrides for the opt-in build-test-gate Stop hook (once a build exists)
# BUILD_CMD=npm run build
# TEST_CMD=npm test
